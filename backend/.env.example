# ─────────────────────────────────────────────────────────────────────────────
# Backend environment configuration
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# NEVER commit .env or any file containing real secrets/keys to version control.
# In production (Render / Railway) set these as platform environment variables,
# not as a file.
# ─────────────────────────────────────────────────────────────────────────────


# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins permitted to call this API.
# MUST be set to your exact Vercel deployment URL(s) in production.
# Leaving this as "*" in production is a security risk — restrict it.
#
# Production example:
#   ALLOWED_ORIGINS=https://phishing-detector.vercel.app
#
# Multiple origins (e.g. preview + production deployments):
#   ALLOWED_ORIGINS=https://phishing-detector.vercel.app,https://phishing-detector-git-main.vercel.app
ALLOWED_ORIGINS=http://localhost:3000


# ── Server ───────────────────────────────────────────────────────────────────
# The port uvicorn listens on.
# Render and Railway inject PORT automatically; the Dockerfile defaults to 8000
# if PORT is not set.  You do not normally need to set this in development.
# PORT=8000

# Uvicorn log level: debug | info | warning | error | critical
# LOG_LEVEL=info


# ── Security note ────────────────────────────────────────────────────────────
# This application currently has no authentication layer.
# If you add API keys, database URLs, JWT secrets, or third-party credentials
# in future, add them below with descriptive comments and NEVER assign real
# values in this file.
#
# Example (do NOT put real values here):
#   API_SECRET_KEY=replace-with-a-random-256-bit-hex-string
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
